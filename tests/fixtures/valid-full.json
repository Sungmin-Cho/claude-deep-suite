{
  "$schema": "../../schemas/suite-extensions.schema.json",
  "schema_version": "1.0",
  "suite": {
    "name": "claude-deep-suite",
    "harness_taxonomy": "boeckeler-2026",
    "telemetry_namespace": "suite"
  },
  "plugins": {
    "deep-work": {
      "runtime": ["node", "bash"],
      "capabilities": ["planning", "phase-guard", "tdd"],
      "artifacts": {
        "writes": [
          ".deep-work/<session>/session-receipt.json",
          ".deep-work/harness-history/harness-sessions.jsonl"
        ],
        "reads": [
          ".deep-dashboard/harnessability-report.json"
        ]
      },
      "hooks_active": ["SessionStart", "PreToolUse", "PostToolUse", "Stop"]
    },
    "deep-review": {
      "runtime": ["bash", "node"],
      "capabilities": ["independent-evaluation"],
      "artifacts": {
        "writes": [".deep-review/reports/<timestamp>-review.md"],
        "reads": [".deep-work/<session>/session-receipt.json"]
      },
      "hooks_active": [],
      "hooks_intentionally_empty_reason": "Evaluator는 user-invocation 기반 trust-boundary 설계"
    },
    "deep-dashboard": {
      "runtime": ["node"],
      "capabilities": ["harnessability-scoring"],
      "artifacts": {
        "writes": [".deep-dashboard/harnessability-report.json"],
        "reads": [".deep-work/**", ".deep-review/**"]
      },
      "hooks_active": [],
      "consumer_only": true
    }
  },
  "data_flow": [
    { "from": "deep-work", "to": "deep-review", "via": "session-receipt" },
    { "from": "deep-work", "to": "deep-dashboard", "via": "session-receipt + harness-sessions.jsonl" },
    { "from": "deep-review", "to": "deep-dashboard", "via": "review reports" },
    { "from": "deep-dashboard", "to": "deep-work", "via": "harnessability-report.json (Phase 1 Research consumes)" }
  ]
}
