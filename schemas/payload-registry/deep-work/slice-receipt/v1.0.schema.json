{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Sungmin-Cho/claude-deep-suite/main/schemas/payload-registry/deep-work/slice-receipt/v1.0.schema.json",
  "title": "deep-work slice-receipt payload v1.0",
  "description": "Authoritative payload schema for deep-work slice-receipt envelope (artifact_kind=slice-receipt, schema.version=1.0). Mirrors deep-work v6.5.0+ emit shape from Phase 2 envelope adoption. parent_run_id chains to the containing session-receipt run_id.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^x-": { "description": "Forward-compat extension namespace." }
  },
  "required": [
    "schema_version",
    "slice_id",
    "status",
    "tdd"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Payload-internal schema version."
    },
    "slice_id": {
      "type": "string",
      "pattern": "^SLICE-[0-9]+$",
      "description": "Slice identifier (SLICE-### with optional zero-padding)."
    },
    "cluster_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["complete", "blocked", "blocked-upstream"],
      "description": "Producer-documented slice statuses (per claude-deep-work@6f23e79 implement-slice-worker.md): `complete` = success, `blocked` = 3-consecutive-failure terminal, `blocked-upstream` = placeholder for slices not started due to upstream block."
    },
    "tdd": {
      "type": "object",
      "additionalProperties": true,
      "required": ["state_transitions"],
      "properties": {
        "state_transitions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "red_verification_output": { "type": "string" }
      }
    },
    "git_before_slice": { "type": "string" },
    "git_after_slice": { "type": "string" },
    "changes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "git_diff": { "type": "string" }
      }
    },
    "sensor_results": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "lint": { "type": "string" },
        "typecheck": { "type": "string" },
        "reviewCheck": { "type": "string" }
      }
    },
    "spec_compliance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "passed": { "type": "boolean" }
      }
    },
    "slice_review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stage1": { "type": "string" },
        "stage2": { "type": "string" }
      }
    },
    "harness_metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_id": { "type": "string" },
        "rework_count": { "type": "integer", "minimum": 0 },
        "tests_passed_first_try": { "type": "boolean" }
      }
    },
    "tests": {
      "type": "object",
      "description": "Optional compact test counts (legacy alternative to sensor_results).",
      "additionalProperties": true,
      "properties": {
        "added": { "type": "integer", "minimum": 0 },
        "failing": { "type": "integer", "minimum": 0 }
      }
    },
    "debug": {
      "type": "object",
      "description": "Emitted on status=blocked path per claude-deep-work@6f23e79 implement-slice-worker.md.",
      "additionalProperties": true,
      "properties": {
        "root_cause_note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
